# ─────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# Docker Compose 사용 시:
#   DATABASE_URL / QDRANT_HOST / QDRANT_PORT 는 docker-compose.yml에서
#   서비스명(postgres, qdrant)으로 자동 오버라이드됩니다.
#   이 파일에서는 OPENAI_API_KEY만 필수로 설정하면 됩니다.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (로컬 직접 실행 시)
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/spatial_notes

# Qdrant (로컬 직접 실행 시)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=spatial_chunks

# OpenAI ★ 필수 입력
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini

# File storage
UPLOAD_DIR=uploads

# Application environment: development | production
# development 설정 시 LOG_LEVEL과 무관하게 DEBUG 강제 적용
APP_ENV=development

# Logging: INFO | DEBUG | ERROR
LOG_LEVEL=INFO

# Log output file path (relative to backend working directory)
LOG_FILE=logs/app.log
