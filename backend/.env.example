# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/spatial_notes

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=spatial_chunks

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini

# File storage
UPLOAD_DIR=uploads

# Application environment: development | production
# When APP_ENV=development, log level is forced to DEBUG
APP_ENV=development

# Logging: INFO | DEBUG | ERROR
LOG_LEVEL=INFO

# Log output file path (relative to backend working directory)
LOG_FILE=logs/app.log
