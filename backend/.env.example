# ─────────────────────────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# When using Docker Compose:
#   DATABASE_URL / QDRANT_HOST / QDRANT_PORT are automatically overridden
#   by service names (postgres, qdrant) defined in docker-compose.yml.
#   Only OPENAI_API_KEY is required to be set in this file.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (when running locally without Docker)
DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/spatial_notes

# Qdrant (when running locally without Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=spatial_chunks

# OpenAI ★ Required
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini

# File storage
UPLOAD_DIR=uploads

# Application environment: development | production
# When set to development, DEBUG level is enforced regardless of LOG_LEVEL
APP_ENV=development

# Logging: INFO | DEBUG | ERROR
LOG_LEVEL=INFO

# Log output file path (relative to backend working directory)
LOG_FILE=logs/app.log
