# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spatial_notes

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=spatial_chunks
REQUIRE_QDRANT_ON_STARTUP=false

# OpenAI
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini

# File storage
UPLOAD_DIR=uploads
